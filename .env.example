# LLM Endpoints (OpenAI-compatible)
PRO_LLM_URL=<OpenAI-compatible endpoint>
FLASH_LLM_URL=<OpenAI-compatible endpoint>

# Model Names
PRO_MODEL=unsloth/Qwen3.6-27B
FLASH_MODEL=unsloth/Qwen3.6-35B

# Behavior
NUM_FLASH_EXPLORERS=4
